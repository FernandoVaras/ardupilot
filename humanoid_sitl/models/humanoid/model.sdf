<?xml version="1.0"?>
<sdf version="1.9">
  <model name="humanoid">
    <static>false</static>

    <!-- TORSO -->
    <link name="torso">
      <pose>0 0 0.785 0 0 0</pose>
      <inertial>
        <mass>3.0</mass>
        <inertia>
          <ixx>0.05</ixx><iyy>0.05</iyy><izz>0.02</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="torso_col">
        <geometry><box><size>0.15 0.18 0.32</size></box></geometry>
      </collision>
      <visual name="torso_vis">
        <geometry><box><size>0.15 0.18 0.32</size></box></geometry>
        <material>
          <ambient>0.4 0.4 0.4 1</ambient>
          <diffuse>0.4 0.4 0.4 1</diffuse>
        </material>
      </visual>
      <sensor name="imu" type="imu">
        <always_on>true</always_on>
        <update_rate>100</update_rate>
      </sensor>
    </link>

    <!-- HEAD -->
    <link name="head">
      <pose>0 0 1.00 0 0 0</pose>
      <inertial>
        <mass>0.3</mass>
        <inertia>
          <ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="head_col">
        <geometry><box><size>0.14 0.11 0.15</size></box></geometry>
      </collision>
      <visual name="head_vis">
        <geometry><box><size>0.14 0.11 0.15</size></box></geometry>
        <material>
          <ambient>0.85 0.85 0.85 1</ambient>
          <diffuse>0.85 0.85 0.85 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="torso_head" type="fixed">
      <parent>torso</parent>
      <child>head</child>
    </joint>

    <!-- LEFT UPPER ARM -->
    <link name="l_upper_arm">
      <pose>0 0.13 0.82 0 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.001</ixx><iyy>0.001</iyy><izz>0.0001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="c">
        <geometry><cylinder><radius>0.025</radius><length>0.20</length></cylinder></geometry>
      </collision>
      <visual name="v">
        <geometry><cylinder><radius>0.025</radius><length>0.20</length></cylinder></geometry>
        <material>
          <ambient>0.4 0.4 0.4 1</ambient>
          <diffuse>0.4 0.4 0.4 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="l_shoulder" type="fixed">
      <parent>torso</parent>
      <child>l_upper_arm</child>
    </joint>

    <!-- LEFT FOREARM -->
    <link name="l_forearm">
      <pose>0 0.13 0.65 0 0 0</pose>
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.0005</ixx><iyy>0.0005</iyy><izz>0.0001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="c">
        <geometry><cylinder><radius>0.015</radius><length>0.14</length></cylinder></geometry>
      </collision>
      <visual name="v">
        <geometry><cylinder><radius>0.015</radius><length>0.14</length></cylinder></geometry>
        <material>
          <ambient>0.75 0.75 0.75 1</ambient>
          <diffuse>0.75 0.75 0.75 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="l_elbow" type="fixed">
      <parent>l_upper_arm</parent>
      <child>l_forearm</child>
    </joint>

    <!-- RIGHT UPPER ARM -->
    <link name="r_upper_arm">
      <pose>0 -0.13 0.82 0 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.001</ixx><iyy>0.001</iyy><izz>0.0001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="c">
        <geometry><cylinder><radius>0.025</radius><length>0.20</length></cylinder></geometry>
      </collision>
      <visual name="v">
        <geometry><cylinder><radius>0.025</radius><length>0.20</length></cylinder></geometry>
        <material>
          <ambient>0.4 0.4 0.4 1</ambient>
          <diffuse>0.4 0.4 0.4 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="r_shoulder" type="fixed">
      <parent>torso</parent>
      <child>r_upper_arm</child>
    </joint>

    <!-- RIGHT FOREARM -->
    <link name="r_forearm">
      <pose>0 -0.13 0.65 0 0 0</pose>
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.0005</ixx><iyy>0.0005</iyy><izz>0.0001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="c">
        <geometry><cylinder><radius>0.015</radius><length>0.14</length></cylinder></geometry>
      </collision>
      <visual name="v">
        <geometry><cylinder><radius>0.015</radius><length>0.14</length></cylinder></geometry>
        <material>
          <ambient>0.75 0.75 0.75 1</ambient>
          <diffuse>0.75 0.75 0.75 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="r_elbow" type="fixed">
      <parent>r_upper_arm</parent>
      <child>r_forearm</child>
    </joint>

    <!-- LEFT THIGH -->
    <link name="l_thigh">
      <pose>0 0.06 0.53 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.004</ixx><iyy>0.004</iyy><izz>0.001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="l_thigh_col">
        <geometry><cylinder><radius>0.025</radius><length>0.20</length></cylinder></geometry>
      </collision>
      <visual name="l_thigh_vis">
        <geometry><cylinder><radius>0.025</radius><length>0.20</length></cylinder></geometry>
        <material>
          <ambient>0.4 0.4 0.4 1</ambient>
          <diffuse>0.4 0.4 0.4 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="l_hip_pitch" type="revolute">
      <parent>torso</parent>
      <child>l_thigh</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1.57</lower><upper>1.57</upper></limit>
        <dynamics><damping>5.0</damping><friction>0.5</friction></dynamics>
      </axis>
    </joint>

    <!-- LEFT SHIN -->
    <link name="l_shin">
      <pose>0 0.06 0.325 0 0 0</pose>
      <inertial>
        <mass>0.3</mass>
        <inertia>
          <ixx>0.003</ixx><iyy>0.003</iyy><izz>0.001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="l_shin_col">
        <geometry><cylinder><radius>0.020</radius><length>0.20</length></cylinder></geometry>
      </collision>
      <visual name="l_shin_vis">
        <geometry><cylinder><radius>0.020</radius><length>0.20</length></cylinder></geometry>
        <material>
          <ambient>0.4 0.4 0.4 1</ambient>
          <diffuse>0.4 0.4 0.4 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="l_knee" type="revolute">
      <parent>l_thigh</parent>
      <child>l_shin</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>0</lower><upper>2.6</upper></limit>
        <dynamics><damping>5.0</damping><friction>0.5</friction></dynamics>
      </axis>
    </joint>

    <!-- LEFT FOOT -->
    <link name="l_foot">
      <pose>0 0.06 0.20 0 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="l_foot_col">
        <geometry><box><size>0.14 0.07 0.03</size></box></geometry>
      </collision>
      <visual name="l_foot_vis">
        <geometry><box><size>0.14 0.07 0.03</size></box></geometry>
        <material>
          <ambient>0.25 0.25 0.28 1</ambient>
          <diffuse>0.25 0.25 0.28 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="l_ankle" type="revolute">
      <parent>l_shin</parent>
      <child>l_foot</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-0.7</lower><upper>0.7</upper></limit>
        <dynamics><damping>2.0</damping><friction>0.2</friction></dynamics>
      </axis>
    </joint>

    <!-- RIGHT THIGH -->
    <link name="r_thigh">
      <pose>0 -0.06 0.53 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.004</ixx><iyy>0.004</iyy><izz>0.001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="r_thigh_col">
        <geometry><cylinder><radius>0.025</radius><length>0.20</length></cylinder></geometry>
      </collision>
      <visual name="r_thigh_vis">
        <geometry><cylinder><radius>0.025</radius><length>0.20</length></cylinder></geometry>
        <material>
          <ambient>0.4 0.4 0.4 1</ambient>
          <diffuse>0.4 0.4 0.4 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="r_hip_pitch" type="revolute">
      <parent>torso</parent>
      <child>r_thigh</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1.57</lower><upper>1.57</upper></limit>
        <dynamics><damping>5.0</damping><friction>0.5</friction></dynamics>
      </axis>
    </joint>

    <!-- RIGHT SHIN -->
    <link name="r_shin">
      <pose>0 -0.06 0.325 0 0 0</pose>
      <inertial>
        <mass>0.3</mass>
        <inertia>
          <ixx>0.003</ixx><iyy>0.003</iyy><izz>0.001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="r_shin_col">
        <geometry><cylinder><radius>0.020</radius><length>0.20</length></cylinder></geometry>
      </collision>
      <visual name="r_shin_vis">
        <geometry><cylinder><radius>0.020</radius><length>0.20</length></cylinder></geometry>
        <material>
          <ambient>0.4 0.4 0.4 1</ambient>
          <diffuse>0.4 0.4 0.4 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="r_knee" type="revolute">
      <parent>r_thigh</parent>
      <child>r_shin</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>0</lower><upper>2.6</upper></limit>
        <dynamics><damping>5.0</damping><friction>0.5</friction></dynamics>
      </axis>
    </joint>

    <!-- RIGHT FOOT -->
    <link name="r_foot">
      <pose>0 -0.06 0.20 0 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="r_foot_col">
        <geometry><box><size>0.14 0.07 0.03</size></box></geometry>
      </collision>
      <visual name="r_foot_vis">
        <geometry><box><size>0.14 0.07 0.03</size></box></geometry>
        <material>
          <ambient>0.25 0.25 0.28 1</ambient>
          <diffuse>0.25 0.25 0.28 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="r_ankle" type="revolute">
      <parent>r_shin</parent>
      <child>r_foot</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-0.7</lower><upper>0.7</upper></limit>
        <dynamics><damping>2.0</damping><friction>0.2</friction></dynamics>
      </axis>
    </joint>

    <!-- ARDUPILOT PLUGIN -->
    <plugin name="ArduPilotPlugin" filename="libArduPilotPlugin.so">
      <fdm_addr>127.0.0.1</fdm_addr>
      <fdm_port_in>9002</fdm_port_in>
      <fdm_port_out>9003</fdm_port_out>
      <connectionTimeoutMaxCount>5</connectionTimeoutMaxCount>
      <modelXYZToAirplaneXForwardZDown degrees="true">0 0 0 0 0 0</modelXYZToAirplaneXForwardZDown>
      <gazeboXYZToNED degrees="true">0 0 0 180 0 90</gazeboXYZToNED>
      <imuName>torso::imu</imuName>
      <control channel="0">
        <jointName>l_hip_pitch</jointName>
        <type>POSITION</type>
        <p_gain>10</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0.1</d_gain>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <multiplier>1.571</multiplier>
        <offset>-0.5</offset>
      </control>
      <control channel="1">
        <jointName>l_knee</jointName>
        <type>POSITION</type>
        <p_gain>10</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0.1</d_gain>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <multiplier>2.618</multiplier>
        <offset>-0.5</offset>
      </control>
      <control channel="2">
        <jointName>l_ankle</jointName>
        <type>POSITION</type>
        <p_gain>10</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0.1</d_gain>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <multiplier>1.4</multiplier>
        <offset>-0.5</offset>
      </control>
      <control channel="3">
        <jointName>r_hip_pitch</jointName>
        <type>POSITION</type>
        <p_gain>10</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0.1</d_gain>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <multiplier>1.571</multiplier>
        <offset>-0.5</offset>
      </control>
      <control channel="4">
        <jointName>r_knee</jointName>
        <type>POSITION</type>
        <p_gain>10</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0.1</d_gain>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <multiplier>2.618</multiplier>
        <offset>-0.5</offset>
      </control>
      <control channel="5">
        <jointName>r_ankle</jointName>
        <type>POSITION</type>
        <p_gain>10</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0.1</d_gain>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <multiplier>1.4</multiplier>
        <offset>-0.5</offset>
      </control>
    </plugin>

  </model>
</sdf>
